model Project {
    id        String   @id @default(uuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    name            String
    domain          String @map("url")
    publicId        String @unique
    apiKeyHash      String
    apiKeyLastFour  String

    organizationId String
    organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

    widgetConfig WidgetConfig?
    reviewers    Reviewer[]
    feedback     Feedback[]
    gitHubLink   ProjectGitHubLink?

    @@index([organizationId])
    @@index([publicId])
    @@map("project")
}

model WidgetConfig {
    id        String   @id @default(uuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    projectId String  @unique
    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    enabled  Boolean @default(true)

    @@map("widget_config")
}

model Reviewer {
    id        String   @id @default(uuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    projectId String
    project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

    name     String
    token    String  @unique
    isActive Boolean @default(true)

    feedback Feedback[]

    @@index([projectId])
    @@map("reviewer")
}

model Feedback {
    id        String   @id @default(uuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    projectId  String
    project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
    reviewerId String
    reviewer   Reviewer @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

    status  String @default("new")
    comment String
    pageUrl String

    clickX   Float?
    clickY   Float?
    selector String?

    browserName    String?
    browserVersion String?
    os             String?
    viewportWidth  Int?
    viewportHeight Int?

    metadata Json?

    screenshotId String?
    screenshot   Asset?  @relation("FeedbackScreenshot", fields: [screenshotId], references: [id], onDelete: SetNull)

    assigneeId String?
    assignee   Member? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

    issueLink FeedbackIssueLink?

    @@index([projectId])
    @@index([reviewerId])
    @@index([assigneeId])
    @@map("feedback")
}
