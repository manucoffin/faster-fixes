{
  "name": "@fasterfixes/react",
  "version": "0.0.4",
  "description": "React feedback widget for FasterFixes. Drop-in component for collecting visual feedback with screenshots, element annotations, and inline comments.",
  "type": "module",
  "license": "MIT",
  "author": "FasterFixes <support@faster-fixes.com> (https://faster-fixes.com)",
  "homepage": "https://faster-fixes.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/manucoffin/faster-fixes.git",
    "directory": "packages/widget-react"
  },
  "bugs": {
    "url": "https://github.com/manucoffin/faster-fixes/issues"
  },
  "keywords": [
    "react",
    "feedback",
    "widget",
    "bug-reporting",
    "visual-feedback",
    "annotation",
    "screenshot",
    "user-feedback",
    "qa",
    "testing",
    "react-component"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@fasterfixes/core": "workspace:*",
    "@floating-ui/react": "^0.27.16",
    "modern-screenshot": "^4.6.8"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  }
}
