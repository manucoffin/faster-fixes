{
  "name": "@fasterfixes/react",
  "version": "0.0.3",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "!dist/**/*.map"],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@fasterfixes/core": "workspace:*",
    "@floating-ui/react": "^0.27.16",
    "html2canvas": "^1.4.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  }
}
