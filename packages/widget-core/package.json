{
  "name": "@fasterfixes/core",
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "main": "./dist/index.js",
