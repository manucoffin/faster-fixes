{
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "statusLine": {
    "type": "command",
    "command": "./.claude/scripts/statusline/statusline.sh"
  },
  "permissions": {
    "allow": [
      "Write(src/**)",
      "Edit(src/**)",
      "Bash(git:*)",
      "Bash(pnpm:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm type:check)",
      "Bash(gh:*)",
      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(node:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "mcp__shadcn__get_component",
      "mcp__shadcn__list_components"
    ],
    "ask": [],
    "deny": [
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(rmdir:*)",
      "Bash(npm run:*)",
      "Bash(pnpm build)",
      "Bash(pnpm build:*)",
      "Bash(pnpm db:seed)",
      "Bash(pnpm db:pull)",
      "Bash(pnpm migrate:dev)",
      "Bash(pnpm migrate:prod)",
      "Bash(pnpm migrate:createonly)",
      "Bash(pnpm migrate:reset)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph update --skip-flows",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph status",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
